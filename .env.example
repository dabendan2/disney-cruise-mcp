# MyDisney Account Credentials
DISNEY_EMAIL=your-email@example.com
DISNEY_PASSWORD=your-password

# Voyage Configuration (Optional)
# SHIP: DA (Disney Adventure), PORT: SIN (Singapore)
SHIP=DA
PORT=SIN

# Google OAuth Token for Gmail OTP (Optional)
# If using Hermes: ~/.hermes/google_token.json
# If using other agents (e.g., OpenCode), provide the absolute path to your token JSON.
# This token can be obtained via 'google-workspace' tools or 'gog cli'.
GOOGLE_TOKEN_PATH=/home/ubuntu/.hermes/google_token.json

# Browser Configuration (Optional)
CDP_PORT=9222
